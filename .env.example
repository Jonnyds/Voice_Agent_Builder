# ── Required ─────────────────────────────────────────────
# The builder brain (turns your description into an agent config).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Vapi PUBLIC key for the in-browser voice call (safe in a browser).
# Optional here — you can paste it into the app's field instead.
VAPI_PUBLIC_KEY=pk-your-public-key-here

# ── Optional (sensible defaults; only set to override) ───
# Model used by the builder to generate configs.
# BUILDER_MODEL=claude-sonnet-4-6

# Seconds to wait on the Anthropic API before giving up.
# BUILDER_TIMEOUT=60

# The voice agent's model on the call (defaults to BUILDER_MODEL).
# VOICE_PROVIDER=anthropic
# VOICE_MODEL=claude-sonnet-4-6